PORT=3001
CORS_ORIGIN=http://localhost:5173
PUPPETEER_HEADLESS=true
PUPPETEER_TIMEOUT=30000
MAX_CONCURRENT_BROWSERS=5
ENABLE_SCREENSHOTS=true
CACHE_ENABLED=true
CACHE_TTL=3600
NODE_ENV=development

# -----------------------------------
# API Provider Configuration
# -----------------------------------
# TMDb (The Movie Database) - https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# TVDb (TheTVDB) - https://thetvdb.com/dashboard/account/apikeys
TVDB_API_KEY=

# Trakt - https://trakt.tv/oauth/applications
TRAKT_API_KEY=

# Real-Debrid - https://real-debrid.com/apitoken
REAL_DEBRID_API_KEY=
# Torrent-to-M3U8 Webhook (replaces Real-Debrid for stream resolution)
TORRENT_WEBHOOK_URL=https://torrent-to-m3u8-play--spikeneedles.github.app/api/webhook/6gxz13
TORRENT_WEBHOOK_KEY=

# AllDebrid - https://alldebrid.com/apikeys/
ALLDEBRID_API_KEY=

# Premiumize - https://www.premiumize.me/account
PREMIUMIZE_API_KEY=

# -----------------------------------
# Gemini 2.5 Flash API Configuration
# -----------------------------------
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# -----------------------------------
# Media Storage Configuration
# -----------------------------------
# Media lists and storage use local SQLite database
# Database file: backend/data/media.db
# Storage files: backend/data/media-storage/
# No configuration needed - works out of the box!

# -----------------------------------
# Authentication
# -----------------------------------
# Authentication (set to true to enable API key authentication)
AUTH_ENABLED=false

# API Keys (comma-separated list of valid API keys)
# Generate keys with: npm run generate-key
# Example: API_KEYS=mls_abc123def456,mls_xyz789ghi012
API_KEYS=

# Admin key for generating new API keys (keep this secret!)
ADMIN_KEY=

# API Key Rate Limiting
API_KEY_RATE_LIMIT=1000
API_KEY_RATE_WINDOW=3600000

# Endpoints that require authentication (comma-separated patterns)
AUTH_REQUIRED_ENDPOINTS=/api/media/*

# -----------------------------------
# Google Drive Integration
# -----------------------------------
# Create credentials at https://console.cloud.google.com/apis/credentials
# 1. Create an OAuth 2.0 Client ID (Web application)
# 2. Add http://localhost:3002/api/drive/callback to Authorized redirect URIs
# 3. Enable the Google Drive API in your project
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3002/api/drive/callback
# URL of the frontend (used to redirect back after OAuth)
FRONTEND_URL=http://localhost:5001
# Optional: pin uploads to a specific Drive folder ID (share link → copy ID from URL)
GOOGLE_DRIVE_FOLDER_ID=
