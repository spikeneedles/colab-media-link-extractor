PORT=3001
CORS_ORIGIN=http://localhost:5173
PUPPETEER_HEADLESS=true
PUPPETEER_TIMEOUT=30000
MAX_CONCURRENT_BROWSERS=5
ENABLE_SCREENSHOTS=true
CACHE_ENABLED=true
CACHE_TTL=3600
NODE_ENV=development

# -----------------------------------
# API Provider Configuration
# -----------------------------------
# TMDb (The Movie Database) - https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# TVDb (TheTVDB) - https://thetvdb.com/dashboard/account/apikeys
TVDB_API_KEY=

# Trakt - https://trakt.tv/oauth/applications
TRAKT_API_KEY=

# Real-Debrid - https://real-debrid.com/apitoken
REAL_DEBRID_API_KEY=
# Torrent-to-M3U8 Webhook (replaces Real-Debrid for stream resolution)
TORRENT_WEBHOOK_URL=https://torrent-to-m3u8-play--spikeneedles.github.app/api/webhook/6gxz13
TORRENT_WEBHOOK_KEY=

# AllDebrid - https://alldebrid.com/apikeys/
ALLDEBRID_API_KEY=

# Premiumize - https://www.premiumize.me/account
PREMIUMIZE_API_KEY=

# -----------------------------------
# Gemini 2.5 Flash API Configuration
# -----------------------------------
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# -----------------------------------
# Media Storage Configuration
# -----------------------------------
# Media lists and storage use local SQLite database
# Database file: backend/data/media.db
# Storage files: backend/data/media-storage/
# No configuration needed - works out of the box!

# -----------------------------------
# Authentication
# -----------------------------------
# Authentication (set to true to enable API key authentication)
AUTH_ENABLED=false

# API Keys (comma-separated list of valid API keys)
# Generate keys with: npm run generate-key
# Example: API_KEYS=mls_abc123def456,mls_xyz789ghi012
API_KEYS=

# Admin key for generating new API keys (keep this secret!)
ADMIN_KEY=

# API Key Rate Limiting
API_KEY_RATE_LIMIT=1000
API_KEY_RATE_WINDOW=3600000

# Endpoints that require authentication (comma-separated patterns)
AUTH_REQUIRED_ENDPOINTS=/api/media/*

# -----------------------------------
# Torrentiolike Sidecar (optional)
# -----------------------------------
# Run the torrentiolike Go service locally or via Docker for multi-source metadata
# and torrent search (YTS / EZTV / TPB / 1337x). No API key needed for Cinemeta.
# Set this to enable the sidecar provider in MetadataScraperService.
# Local dev:  go run . in Antigravity_projects/torrentiolike (serves on :8080)
# Docker:     included in docker-compose.yml as the `torrentiolike` service
TORRENTIOLIKE_URL=

# -----------------------------------
# Google Drive Integration
# -----------------------------------
# Create credentials at https://console.cloud.google.com/apis/credentials
# 1. Create an OAuth 2.0 Client ID (Web application)
# 2. Add http://localhost:3002/api/drive/callback to Authorized redirect URIs
# 3. Enable the Google Drive API in your project
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3002/api/drive/callback
# URL of the frontend (used to redirect back after OAuth)
FRONTEND_URL=http://localhost:5001
# Optional: pin uploads to a specific Drive folder ID (share link → copy ID from URL)
GOOGLE_DRIVE_FOLDER_ID=

# -----------------------------------
# Free Metadata Enrichment Services
# -----------------------------------

# FanArt.tv — HD logos, clearart, posters, backgrounds (free personal key)
# Register: https://fanart.tv/get-an-api-key/
FANART_TV_API_KEY=

# OMDb API — posters, plot, multi-source ratings (free: 1,000 req/day)
# Register: https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=

# MDBList — aggregate ratings from IMDb, TMDb, Trakt, Letterboxd, RT, Metacritic (free: 1,000 req/day)
# Register: https://mdblist.com/api/
MDBLIST_API_KEY=

# Jikan (MyAnimeList) — anime metadata + images — NO KEY NEEDED, always enabled
# Rate limited to 3 req/sec automatically


# Install: pip install yt-dlp  OR  winget install yt-dlp
# If not in PATH, set the binary path explicitly
YTDLP_BIN=yt-dlp
YTDLP_TIMEOUT=60000
# Optional: path to cookies.txt for authenticated sites
YTDLP_COOKIES=
# Optional: proxy for yt-dlp requests
YTDLP_PROXY=

# -----------------------------------
# Shodan / Censys Xtream Panel Discovery (optional)
# -----------------------------------
# Shodan API key: https://account.shodan.io/
SHODAN_API_KEY=
# Censys API credentials: https://search.censys.io/account/api
CENSYS_API_ID=
CENSYS_API_SECRET=
# Max results per Shodan/Censys query (default: 100)
SHODAN_MAX_RESULTS=100

# -----------------------------------
# CAPTCHA Solving (optional)
# -----------------------------------
# Provider: twocaptcha | capmonster  (default: twocaptcha)
CAPTCHA_PROVIDER=twocaptcha
# 2Captcha API key: https://2captcha.com/enterpage
TWOCAPTCHA_KEY=
# CapMonster API key: https://capmonster.cloud/
CAPMONSTER_KEY=
# Timeout waiting for CAPTCHA solution (ms, default: 120000)
CAPTCHA_TIMEOUT=120000

# -----------------------------------
# DNS Subdomain Discovery (optional)
# -----------------------------------
# Parallel DNS lookups (default: 50)
DNS_DISCOVERY_CONCURRENCY=50
# DNS lookup timeout ms (default: 3000)
DNS_DISCOVERY_TIMEOUT=3000

# -----------------------------------
# Smart Recrawl Scheduler (optional)
# -----------------------------------
# SQLite file for recrawl state (default: data/smart-recrawl.db)
SMART_RECRAWL_DB=
# How often the watcher tick runs (ms, default: 1800000 = 30 min)
SMART_RECRAWL_INTERVAL_MS=1800000
# Max concurrent recrawl checks (default: 5)
SMART_RECRAWL_CONCURRENCY=5
# Disable auto-recrawl watcher (default: false)
# DISABLE_SMART_RECRAWL=true

# -----------------------------------
# Playwright Browser Pool (optional)
# -----------------------------------
# Install browsers: npx playwright install
# Browsers to use: chromium, firefox, webkit (comma-separated, default: chromium)
PLAYWRIGHT_BROWSERS=chromium
# Max pages open simultaneously (default: 5)
PLAYWRIGHT_MAX_PAGES=5
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT=30000

# -----------------------------------
# Proxy Pool Auto-Refresh (optional)
# -----------------------------------
# Webshare API key for premium free-tier proxies: https://proxy.webshare.io/
WEBSHARE_API_KEY=
# Disable automatic free-proxy refresh on startup (default: false)
# DISABLE_PROXY_AUTOFETCH=true
